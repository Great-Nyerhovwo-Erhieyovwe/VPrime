# Example environment variables for local development and production

# Frontend origin allowed by backend CORS
# On Render, set this to your deployed frontend hostname.
FRONTEND_ORIGIN=https://vprimecapital.onrender.com

# Backend URL used by the frontend to call API routes
# On Render, set this to your deployed backend hostname.
VITE_API_URL=https://vprimeapi.onrender.com

# MongoDB connection string for the backend
#DATABASE_URL=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret and expiration settings used by the backend
#JWT_SECRET=your-jwt-secret
#JWT_EXPIRES_IN=24h
